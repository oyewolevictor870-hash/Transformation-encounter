# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transformation_encounter
DB_USER=postgres
DB_PASSWORD=1234

# JWT Secret (change to a long random string)
JWT_SECRET=your_very_long_secret_key_here_change_this

# Server Port
PORT=3000

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=Transformation Encounter <your_email@gmail.com>

# Paystack Keys (add when ready)
PAYSTACK_PUBLIC_KEY=pk_live_your_key_here
PAYSTACK_SECRET_KEY=sk_live_your_key_here

# App URL
APP_URL=http://localhost:3000

# Admin Default Account (used during first setup)
ADMIN_EMAIL=Admin@transformationencounter.org
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Omikunle
